// Function for Flight Costs with Age Logic (using Switch as requested)
double flycost(int location, int dewasa, int k1, int k2) {
    switch(location) {
        case 1: flight = (dewasa * 750) + (k1 * 750 * 0.1) + (k2 * 750 * 0.6); break;
        case 2: flight = (dewasa * 420) + (k1 * 420 * 0.1) + (k2 * 420 * 0.6); break;
        case 3: flight = (dewasa * 1300) + (k1 * 1300 * 0.1) + (k2 * 1300 * 0.6); break;
        case 4: flight = (dewasa * 530) + (k1 * 530 * 0.1) + (k2 * 530 * 0.6); break;
        default: flight = 0;
    }
    return flight;
}

// Function for Accommodation with Nested Selection and Math
double roomcost(int location, int type, int nights, int rooms) {
    double price = 0;
    
    // Mapping Location and Room Type to Prices
    if (location == 1) { // Kuching
        if (type == 1) price = 140; else if (type == 2) price = 230; else price = 350;
    } else if (location == 2) { // Terengganu
        if (type == 1) price = 150; else if (type == 2) price = 220; else price = 330;
    } else if (location == 3) { // KK
        if (type == 1) price = 120; else if (type == 2) price = 180; else price = 275;
    } else { // Langkawi
        if (type == 1) price = 160; else if (type == 2) price = 240; else price = 350;
    }

    double subtotal = price * nights * rooms;
    
    // Apply 10% discount for stays exceeding 7 nights
    if (nights > 7) {
        subtotal = subtotal * 0.90; 
    }
    
    return subtotal;
}
